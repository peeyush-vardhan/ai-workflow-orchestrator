# ── Weave environment variables ──────────────────────────────────────────────
# Copy this file to .env and fill in the values.

# LLM Provider — omit to run in mock mode (no API calls made)
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...    # fallback if Anthropic key is not set

# Auth
JWT_SECRET=change-this-to-a-long-random-string-in-production
ADMIN_EMAIL=you@example.com   # email that receives is_admin=true on login

# Frontend URL (CORS origin)
FRONTEND_URL=http://localhost:5173

# Email OTP (Resend — https://resend.com)
RESEND_API_KEY=re_...
EMAIL_FROM=onboarding@resend.dev   # change to noreply@yourdomain.com once verified

# Dev mode — returns OTP code in API response, skip real email in CI
DEV_MODE=true

# Database (SQLite — created automatically, do not commit the .db file)
DB_PATH=workflows.db

# LinkedIn OAuth (optional — for post-to-LinkedIn export)
# LINKEDIN_CLIENT_ID=...
# LINKEDIN_CLIENT_SECRET=...
